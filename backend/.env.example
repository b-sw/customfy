PORT=3000
OUR_ENV=dev
MONGO_URL=mongodb://localhost:2137/customfy
JWT_SECRET=change-me
JWT_EXPIRES_IN=15m
WEB_APP_URL=http://localhost:5173

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Required for login. Both redirect URIs must be registered as Authorized
# redirect URIs in the Google console.
#  - GOOGLE_REDIRECT_URI: the production URL (used by the deployed frontend).
#  - GOOGLE_REDIRECT_URI_ALTERNATIVE: localhost, used when the client sends
#    forceLocalLogin (i.e. the frontend is running on localhost).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://customfy.vercel.app
GOOGLE_REDIRECT_URI_ALTERNATIVE=http://localhost:5173

# Optional dev-only fallback: email-only login (no Google). Leave false to use
# real Google OAuth locally. Never enable in production.
ALLOW_LOCAL_LOGIN=false
