# =============================================================================
# Deployment credentials for GitHub Actions
# -----------------------------------------------------------------------------
# These are NOT loaded by the apps at runtime. They are the secrets/variables
# the CI/CD workflows read to build the Docker image and deploy it to your VPS.
#
# Set them in your repository:
#   Settings -> Secrets and variables -> Actions
#
# Quick CLI alternative (GitHub CLI), run from the repo root:
#   gh secret set DOCKERHUB_USERNAME --body "..."
#   gh variable set VITE_API_URL --body "https://api.example.com"
# =============================================================================

# --- Repository SECRETS (backend-deploy.yml) ---------------------------------

# Docker Hub (where the backend image is pushed)
DOCKERHUB_USERNAME=your-dockerhub-username
DOCKERHUB_TOKEN=dckr_pat_xxxxxxxxxxxxxxxxxxxx
DOCKER_IMAGE_NAME=your-dockerhub-username/customfy-backend

# VPS access over SSH (where the image is pulled & run)
SSH_HOST=123.123.123.123
SSH_USERNAME=deploy
SSH_PORT=22
SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"

# Backend runtime values injected into the container on the VPS
JWT_SECRET=generate-a-long-random-string
MONGO_URL=mongodb://user:password@host:27017/db?authSource=db
WEB_APP_URL=https://customfy.vercel.app
# Localhost web app URL, used when a request carries forceLocalLogin.
WEB_APP_URL_ALTERNATIVE=http://localhost:5173
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx
# The frontend redirects to its own origin (window.location.origin), so this
# must EXACTLY equal the deployed frontend origin (the Vercel URL, no trailing
# slash) and be an Authorized redirect URI in Google.
GOOGLE_REDIRECT_URI=https://customfy.vercel.app
# Localhost origin, used when the frontend sends forceLocalLogin (local dev).
# Also register it as an Authorized redirect URI.
GOOGLE_REDIRECT_URI_ALTERNATIVE=http://localhost:5173

# --- Frontend (configured in the Vercel project settings, NOT GitHub) ---------
# These are public (they ship in the browser bundle).
VITE_API_URL=https://api.your-vps-domain.com
VITE_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
