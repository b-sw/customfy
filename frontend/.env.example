# Remote backend URL (used in production builds, e.g. on Vercel).
# When the app runs on localhost it ignores this and talks to http://localhost:3003.
VITE_API_URL=https://api.your-vps-domain.com

# Google OAuth client ID (public; safe to ship to the browser).
VITE_GOOGLE_CLIENT_ID=

# Optional dev-only fallback: show an email-only login form instead of Google.
# Leave false to use real Google OAuth locally. Never enable in production.
VITE_ALLOW_LOCAL_LOGIN=false
